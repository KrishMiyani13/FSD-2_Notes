<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f7f6; text-align: center; padding-top: 50px; }
        form { display: inline-block; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        input { margin: 10px; padding: 8px; width: 200px; }
        button { padding: 10px 20px; background: 'red'; color: yellow; border: none; border-radius: 10px; cursor: pointer; }
        button:hover { background: #007f66; }
    </style>
</head>
<body>
    <form action="/check" method="POST">
        <input type="text" name="username" placeholder="Username" required /><br>
        <input type="password" name="password" placeholder="Password" /><br>
        <button type="submit">Submit</button>
    </form>
</body>
</html>
